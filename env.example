# ══════════════════════════════════════════════════════════════════
#  Личный бот — Environment Variables Reference
#  Копируйте этот файл в .env и заполните все значения.
#  Генерация случайных секретов: openssl rand -base64 48
# ══════════════════════════════════════════════════════════════════

# ── Домен / инфраструктура ────────────────────────────────────────
DOMAIN_NAME=yourdomain.com
SUBDOMAIN=webapp
SSL_EMAIL=admin@yourdomain.com
GENERIC_TIMEZONE=Europe/Moscow
NODE_ENV=production

# ── PostgreSQL (Docker Compose service) ──────────────────────────
POSTGRES_DB=telegram_webapp
POSTGRES_USER=webapp_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD   # openssl rand -base64 32

# Connection string used by the apps (assembled from vars above in compose)
DATABASE_URL=postgresql://webapp_user:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/telegram_webapp

# ── Redis ────────────────────────────────────────────────────────
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD       # openssl rand -base64 32
REDIS_URL=redis://:REPLACE_WITH_STRONG_PASSWORD@redis:6379

# ── JWT ──────────────────────────────────────────────────────────
# MUST be at least 32 characters. Generate: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_MIN_32_CHAR_SECRET
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── Telegram ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
BOT_USERNAME=your_bot_username   # without @

# Webhook secret — MUST be at least 32 chars in production.
# Generate: openssl rand -base64 48
# Set the same value in both backend AND bot env files.
TELEGRAM_WEBHOOK_SECRET=REPLACE_WITH_MIN_32_CHAR_SECRET

# ── WebApp / CORS ─────────────────────────────────────────────────
WEBAPP_URL=https://webapp.yourdomain.com
CORS_ORIGINS=https://webapp.yourdomain.com

# ── Backend server ────────────────────────────────────────────────
PORT=3100
HOST=0.0.0.0
API_URL=http://backend:3100

# ── Bot webhook server ────────────────────────────────────────────
BOT_WEBHOOK_PORT=3200

# ── Next.js webapp ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# ── Payment webhooks ──────────────────────────────────────────────
# Both secrets must be set before connecting a real payment provider.
# Without them the webhook endpoint rejects ALL requests (fail-closed).
# Generate: openssl rand -base64 48
LAVA_WEBHOOK_SECRET=REPLACE_WITH_LAVA_SECRET
CP_WEBHOOK_SECRET=REPLACE_WITH_CP_SECRET

# ── Feature flags ─────────────────────────────────────────────────
ENABLE_AI=false
OPENAI_API_KEY=

# ── Monitoring / admin ────────────────────────────────────────────
PGADMIN_EMAIL=admin@yourdomain.com
PGADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

GRAFANA_USER=admin
GRAFANA_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Basic-auth hashes for Traefik/metrics endpoints.
# Generate: echo $(htpasswd -nb admin YOUR_PASSWORD) | sed -e s/\\$/\\$\\$/g
TRAEFIK_AUTH=admin:$$2y$$10$$...your_bcrypt_hash_here
METRICS_AUTH=admin:$$2y$$10$$...your_bcrypt_hash_here
