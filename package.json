{
  "name": "showcase-platform",
  "private": true,
  "version": "2.0.0",
  "description": "Telegram WebApp Showcase Platform — демо кейсов возможностей ботов",
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "pnpm --filter @showcase/backend db:generate",
    "db:migrate": "pnpm --filter @showcase/backend db:migrate",
    "db:studio": "pnpm --filter @showcase/backend db:studio",
    "clean": "turbo clean && find . -name 'node_modules' -type d -prune -exec rm -rf {} +"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "@biomejs/biome": "^1.9.4"
  }
}
