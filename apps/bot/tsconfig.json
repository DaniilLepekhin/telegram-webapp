{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun-types"],
    "paths": {
      "@showcase/shared": ["../../packages/shared/src/index.ts"],
      "@showcase/backend/*": ["../backend/src/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*", "../../packages/shared/src/**/*", "../backend/src/db/schema.ts"],
  "exclude": ["node_modules"]
}
